{
  "manifest_version": 3,
  "name": "Airdrop Scout (MVP)",
  "version": "0.1.0",
  "description": "Yeni çıkan early-stage projeleri (airdrop/points/testnet sinyali) GitHub üzerinden bulur; basit risk/skam uyarıları üretir.",
  "action": {
    "default_title": "Airdrop Scout",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://rdap.org/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
